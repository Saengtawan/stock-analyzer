[Unit]
Description=Auto Trading Engine - Gap Scanner & Trading System
After=network.target

[Service]
Type=simple
User=saengtawan
WorkingDirectory=/home/saengtawan/work/project/cc/stock-analyzer
Environment="PATH=/home/saengtawan/.pyenv/versions/cc/bin:/usr/local/bin:/usr/bin"
Environment="PYTHONUNBUFFERED=1"
EnvironmentFile=/home/saengtawan/work/project/cc/stock-analyzer/.env

ExecStart=/home/saengtawan/.pyenv/versions/cc/bin/python src/auto_trading_engine.py

# Always restart (even after manual kill/pkill) — engine must never stay down
Restart=always
RestartSec=5s

# Logging
StandardOutput=append:/home/saengtawan/work/project/cc/stock-analyzer/logs/auto_trading_engine.log
StandardError=append:/home/saengtawan/work/project/cc/stock-analyzer/logs/auto_trading_engine_error.log

[Install]
WantedBy=multi-user.target
