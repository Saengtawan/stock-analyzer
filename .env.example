# ===============================================
# Stock Analyzer Environment Variables
# ===============================================

# Copy this file to .env and fill in your actual API keys
# cp .env.example .env

# ===============================================
# API Keys (Required for enhanced data sources)
# ===============================================

# Financial Modeling Prep (FMP) API Key
# Sign up: https://financialmodelingprep.com/developer/docs
# Free tier: 300 calls per day
# Used for: Comprehensive fundamental data, financial statements, ratios
FMP_API_KEY=your_fmp_api_key_here

# Tiingo API Key
# Sign up: https://api.tiingo.com/
# Free tier: 500 requests per hour
# Used for: High-quality price data, intraday data, cryptocurrency
TIINGO_API_KEY=your_tiingo_api_key_here

# ===============================================
# Optional: Database Configuration
# ===============================================

# SQLite Database Path (default: data/stock_analyzer.db)
DATABASE_PATH=data/stock_analyzer.db

# Cache Directory (default: data/cache/)
CACHE_DIR=data/cache/

# ===============================================
# Optional: Logging Configuration
# ===============================================

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log File Path (leave empty for console only)
LOG_FILE=logs/stock_analyzer.log

# ===============================================
# Optional: Analysis Configuration
# ===============================================

# Default time horizon for analysis (short, medium, long)
DEFAULT_TIME_HORIZON=medium

# Default account value for position sizing (USD)
DEFAULT_ACCOUNT_VALUE=100000

# Risk per trade percentage (0.01 = 1%)
DEFAULT_RISK_PER_TRADE=0.02

# ===============================================
# Optional: Web Interface Configuration
# ===============================================

# Flask development server settings
FLASK_ENV=development
FLASK_DEBUG=true
FLASK_PORT=5000
FLASK_HOST=127.0.0.1

# Secret key for Flask sessions (generate a random string for production)
FLASK_SECRET_KEY=your_secret_key_here_change_in_production

# ===============================================
# Optional: Backtesting Configuration
# ===============================================

# Default backtesting period
BACKTEST_DEFAULT_PERIOD=2y

# Default initial capital for backtesting
BACKTEST_INITIAL_CAPITAL=100000

# Commission rate (0.001 = 0.1%)
BACKTEST_COMMISSION=0.001

# Slippage rate (0.0005 = 0.05%)
BACKTEST_SLIPPAGE=0.0005

# ===============================================
# Optional: API Rate Limiting
# ===============================================

# Enable rate limiting (true/false)
ENABLE_RATE_LIMITING=true

# Rate limit window in seconds
RATE_LIMIT_WINDOW=60

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ===============================================
# Optional: Cache Configuration
# ===============================================

# Enable caching (true/false)
ENABLE_CACHING=true

# Cache TTL for price data (seconds)
PRICE_DATA_CACHE_TTL=300

# Cache TTL for fundamental data (seconds)
FUNDAMENTAL_DATA_CACHE_TTL=3600

# Cache TTL for technical indicators (seconds)
TECHNICAL_CACHE_TTL=900

# ===============================================
# Optional: Data Source Priority
# ===============================================

# Primary data source (yfinance, fmp, tiingo)
PRIMARY_DATA_SOURCE=yfinance

# Backup data source for fundamentals
BACKUP_DATA_SOURCE=fmp

# Backup data source for price data
PRICE_BACKUP_SOURCE=tiingo

# ===============================================
# Development & Testing
# ===============================================

# Enable development mode (additional logging, debug features)
DEVELOPMENT_MODE=false

# Enable test mode (use mock data, skip API calls)
TEST_MODE=false

# Mock data directory for testing
MOCK_DATA_DIR=tests/mock_data/

# ===============================================
# Security Settings
# ===============================================

# Enable API key encryption (requires additional setup)
ENCRYPT_API_KEYS=false

# Encryption key (generate a strong key for production)
ENCRYPTION_KEY=your_encryption_key_here

# ===============================================
# Performance Settings
# ===============================================

# Maximum concurrent API requests
MAX_CONCURRENT_REQUESTS=5

# Request timeout in seconds
REQUEST_TIMEOUT=30

# Connection pool size
CONNECTION_POOL_SIZE=10

# ===============================================
# Monitoring & Alerts
# ===============================================

# Enable performance monitoring
ENABLE_MONITORING=false

# Alert webhook URL (for notifications)
ALERT_WEBHOOK_URL=

# Email settings for alerts (optional)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# ===============================================
# Notes
# ===============================================

# 1. Never commit the actual .env file to version control
# 2. Keep your API keys secure and rotate them regularly
# 3. Use strong passwords and encryption keys in production
# 4. Monitor your API usage to avoid rate limits
# 5. Set appropriate cache TTLs based on your use case
# 6. Test your configuration with the provided test scripts

# ===============================================
# Quick Setup Commands
# ===============================================

# Copy this file:
# cp .env.example .env

# Set minimal required variables:
# export FMP_API_KEY="your_fmp_key"
# export TIINGO_API_KEY="your_tiingo_key"

# Test your setup:
# python src/test_main.py

# Run the application:
# python src/main.py analyze --symbol AAPL