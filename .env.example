# ===============================================
# Stock Analyzer Environment Variables (100% Free Setup)
# ===============================================

# Copy this file to .env and fill in your email
# cp .env.example .env

# ===============================================
# Free APIs Only - No Paid Subscriptions Required!
# ===============================================

# SEC EDGAR API - Completely FREE, no key required
# Used for: Insider trading data, institutional holdings, SEC filings
# Set your email for compliance (required by SEC)
SEC_USER_AGENT=StockAnalyzer your-email@domain.com

# Yahoo Finance - FREE via yfinance library (no key required)
# Used for: Price data, earnings data, analyst targets, financial metrics
# No setup required - works out of the box!

# Tiingo API Key (OPTIONAL - FREE tier available)
# Sign up: https://api.tiingo.com/
# Free tier: 500 requests per hour
# Used for: Enhanced price data, intraday data
# Leave empty to use Yahoo Finance only
TIINGO_API_KEY=

# ===============================================
# Removed Dependencies
# ===============================================

# ❌ Financial Modeling Prep (FMP) - REMOVED (was paid)
# ❌ Alpha Vantage - REMOVED (too limited: 25 calls/day)

# Now using 100% FREE alternatives:
# ✅ SEC EDGAR for insider/institutional data (unlimited)
# ✅ Yahoo Finance for earnings/analyst/price data (unlimited)
# ✅ Enhanced mock data system for reliable fallbacks

# ===============================================
# Optional: Database Configuration
# ===============================================

# SQLite Database Path (default: data/stock_analyzer.db)
DATABASE_PATH=data/stock_analyzer.db

# Cache Directory (default: data/cache/)
CACHE_DIR=data/cache/

# ===============================================
# Optional: Logging Configuration
# ===============================================

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log File Path (leave empty for console only)
LOG_FILE=logs/stock_analyzer.log

# ===============================================
# Optional: Analysis Configuration
# ===============================================

# Default time horizon for analysis (short, medium, long)
DEFAULT_TIME_HORIZON=medium

# Default account value for position sizing (USD)
DEFAULT_ACCOUNT_VALUE=100000

# Risk per trade percentage (0.01 = 1%)
DEFAULT_RISK_PER_TRADE=0.02

# ===============================================
# Optional: Web Interface Configuration
# ===============================================

# Flask development server settings
FLASK_ENV=development
FLASK_DEBUG=true
FLASK_PORT=5000
FLASK_HOST=127.0.0.1

# Secret key for Flask sessions (generate a random string for production)
FLASK_SECRET_KEY=your_secret_key_here_change_in_production

# ===============================================
# Optional: Backtesting Configuration
# ===============================================

# Default backtesting period
BACKTEST_DEFAULT_PERIOD=2y

# Default initial capital for backtesting
BACKTEST_INITIAL_CAPITAL=100000

# Commission rate (0.001 = 0.1%)
BACKTEST_COMMISSION=0.001

# Slippage rate (0.0005 = 0.05%)
BACKTEST_SLIPPAGE=0.0005

# ===============================================
# Optional: API Rate Limiting
# ===============================================

# Enable rate limiting (true/false)
ENABLE_RATE_LIMITING=true

# Rate limit window in seconds
RATE_LIMIT_WINDOW=60

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ===============================================
# Optional: Cache Configuration
# ===============================================

# Enable caching (true/false)
ENABLE_CACHING=true

# Cache TTL for price data (seconds)
PRICE_DATA_CACHE_TTL=300

# Cache TTL for fundamental data (seconds)
FUNDAMENTAL_DATA_CACHE_TTL=3600

# Cache TTL for technical indicators (seconds)
TECHNICAL_CACHE_TTL=900

# ===============================================
# Data Source Priority (All Free!)
# ===============================================

# Primary data source (Yahoo Finance - free and unlimited)
PRIMARY_DATA_SOURCE=yfinance

# Backup data source for price data (Tiingo - free tier)
PRICE_BACKUP_SOURCE=tiingo

# Insider/Institutional data source (SEC EDGAR - completely free)
INSIDER_DATA_SOURCE=sec_edgar

# Mock data fallback (always available)
MOCK_DATA_FALLBACK=true

# ===============================================
# Development & Testing
# ===============================================

# Enable development mode (additional logging, debug features)
DEVELOPMENT_MODE=false

# Enable test mode (use mock data, skip API calls)
TEST_MODE=false

# Mock data directory for testing
MOCK_DATA_DIR=tests/mock_data/

# ===============================================
# Security Settings
# ===============================================

# Enable API key encryption (requires additional setup)
ENCRYPT_API_KEYS=false

# Encryption key (generate a strong key for production)
ENCRYPTION_KEY=your_encryption_key_here

# ===============================================
# Performance Settings
# ===============================================

# Maximum concurrent API requests
MAX_CONCURRENT_REQUESTS=5

# Request timeout in seconds
REQUEST_TIMEOUT=30

# Connection pool size
CONNECTION_POOL_SIZE=10

# ===============================================
# Monitoring & Alerts
# ===============================================

# Enable performance monitoring
ENABLE_MONITORING=false

# Alert webhook URL (for notifications)
ALERT_WEBHOOK_URL=

# Email settings for alerts (optional)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# ===============================================
# 100% Free Setup Guide
# ===============================================

# 1. ZERO COST setup (works immediately):
#    - Copy this file: cp .env.example .env
#    - Set your email: SEC_USER_AGENT=MyApp my@email.com
#    - Run: python src/main.py analyze --symbol AAPL
#    - All features work with mock/Yahoo data!

# 2. Enhanced free setup (optional):
#    - Add Tiingo key for better price data
#    - Everything else works without any keys

# 3. What you get for FREE:
#    ✅ Complete stock analysis
#    ✅ Factor Health Monitor
#    ✅ Recovery Signal Dashboard
#    ✅ Earnings & analyst data (Yahoo)
#    ✅ Insider/institutional data (SEC EDGAR)
#    ✅ Technical analysis (Yahoo prices)
#    ✅ Web interface
#    ✅ Backtesting
#    ✅ Risk management
#    ✅ All enhanced indicators

# ===============================================
# Quick Start Commands (100% Free)
# ===============================================

# Minimal setup:
# cp .env.example .env
# Edit .env and set: SEC_USER_AGENT=MyApp my@email.com
# python src/web/app.py

# Test analysis:
# python src/api/yahoo_enhanced_client.py

# Run web interface:
# cd src && python web/app.py

# Test system:
# python src/test_main.py